# Public URL the browser uses to reach the backend.
# Local dev: http://localhost:8000
# NREC:      http://158.37.63.124:8000
VITE_API_BASE_URL=http://localhost:8000

# Shared API key, must match FIREGUARD_API_KEY on the backend.
# This value is compiled into the JS bundle and therefore visible in
# browser devtools. It authorizes the frontend deployment, not a user.
VITE_API_KEY=change-me-use-secrets.token_urlsafe-32
