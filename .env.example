# FireGuard Cloud — environment variables
# Copy this file to .env and fill in real values before running `docker compose up`.
#
# The same .env is read by docker-compose. Do NOT commit the filled-in .env.

# --- Database ------------------------------------------------------------
# Postgres password used by the `postgres` service and the backend's
# FIREGUARD_DATABASE_URL. Pick something random and private.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- API key authentication ---------------------------------------------
# Strong random key shared between backend and frontend.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# The frontend bakes this into its JS bundle at build time, so it is
# visible in browser devtools. It authorizes the frontend deployment,
# it is NOT a per-user secret.
FIREGUARD_API_KEY=change-me-use-secrets.token_urlsafe-32

# JWT signing secret for user sessions. Must be 32+ characters.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
FIREGUARD_JWT_SECRET=change-me-use-secrets.token_urlsafe-48-minimum-32-chars

# --- Frontend ------------------------------------------------------------
# Public URL the browser uses to reach the backend. For local dev, leave it
# at http://localhost:8000. For NREC, set it to http://158.37.63.124:8000.
VITE_API_BASE_URL=http://localhost:8000
